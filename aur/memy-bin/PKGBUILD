# Maintainer: Andrew Ferrier <andrew.ferrier@example.com>
pkgname=memy-bin
pkgver=0.18.0
pkgrel=1
pkgdesc='Track and recall frequently and recently used files or directories (pre-built binary)'
arch=('x86_64' 'aarch64')
url='https://github.com/andrewferrier/memy'
license=('MIT')
provides=('memy')
conflicts=('memy')
source=("LICENSE::https://raw.githubusercontent.com/andrewferrier/memy/v$pkgver/LICENSE")
source_x86_64=("$pkgname-$pkgver-x86_64.tar.gz::https://github.com/andrewferrier/memy/releases/download/v$pkgver/memy-linux-x86_64.tar.gz")
source_aarch64=("$pkgname-$pkgver-aarch64.tar.gz::https://github.com/andrewferrier/memy/releases/download/v$pkgver/memy-linux-aarch64.tar.gz")
sha256sums=('5bfe106c6a46ccea9584d71a3df6e8ca0c0384d848f1f26781e1dd743b4e534a')
sha256sums_x86_64=('1f503d4e40911f27bba5907e6aec524497be5a1ea73047022c31634cdc455c39')
sha256sums_aarch64=('6f2ea8baa41d96db631b03f9f9c810a69938e7899b7db852e975f42cf4447adb')

package() {
    # Binary
    install -Dm755 memy -t "$pkgdir/usr/bin/"

    # Man pages
    install -Dm644 man/*.1 -t "$pkgdir/usr/share/man/man1/"
    install -Dm644 man/memy.toml.5 -t "$pkgdir/usr/share/man/man5/"

    # Shell completions (generated from the installed binary)
    install -dm755 "$pkgdir/usr/share/bash-completion/completions/"
    install -dm755 "$pkgdir/usr/share/zsh/site-functions/"
    install -dm755 "$pkgdir/usr/share/fish/vendor_completions.d/"
    "$pkgdir/usr/bin/memy" completions bash \
        > "$pkgdir/usr/share/bash-completion/completions/memy"
    "$pkgdir/usr/bin/memy" completions zsh \
        > "$pkgdir/usr/share/zsh/site-functions/_memy"
    "$pkgdir/usr/bin/memy" completions fish \
        > "$pkgdir/usr/share/fish/vendor_completions.d/memy.fish"

    # License
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"

    # Documentation
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
